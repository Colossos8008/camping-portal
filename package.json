{
  "name": "camping-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "dotenv -e .env -- prisma generate",
    "db:migrate": "dotenv -e .env -- prisma migrate dev",
    "db:deploy": "dotenv -e .env -- prisma migrate deploy",
    "db:push": "node scripts/blocked-db-push.mjs",
    "postinstall": "prisma generate",
    "verify:hero": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/verify-heroimageurl-roundtrip.ts",
    "verify:google-hero-proxy": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/verify-google-hero-proxy.ts",
    "verify:hero-type-scoring": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/verify-hero-type-scoring.ts",
    "verify:hero-candidate-selection": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/verify-hero-candidate-selection.ts",
    "verify:hero-autofill-ids-mode": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/verify-hero-autofill-ids-mode.ts",
    "verify:sightseeing-rating": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/verify-sightseeing-rating.ts",
    "import:sightseeing:seed": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/import-sightseeing-seed.ts",
    "import:sightseeing:seed:normandie": "npm run import:sightseeing:seed -- --region=normandie",
    "import:sightseeing:seed:bretagne": "npm run import:sightseeing:seed -- --region=bretagne",
    "import:sightseeing:seed:nievern": "npm run import:sightseeing:seed -- --near=nievern",
    "import:sightseeing:seed:nievern:highlights": "npm run import:sightseeing:seed -- --near=nievern --highlight-mode --limit=10",
    "import:sightseeing:seed:nievern:curated": "npm run import:sightseeing:seed -- --curated-set=nievern-highlights",
    "dedupe:sightseeing:external-id": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/dedupe-sightseeing-by-external-id.ts",
    "repair:curated:sightseeing-identities": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/repair-curated-sightseeing-identities.ts",
    "check:hero-endpoint-health": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/check-hero-endpoint-health.ts",
    "verify:curated-hero-urls": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/validate-curated-hero-urls.ts",
    "smoke:curated:nievern-highlights": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/smoke-test-curated-nievern-highlights.ts",
    "verify:curated-priority-coordinates": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/verify-curated-priority-coordinates.ts",
    "assist:curated-priority-osm": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/assist-curated-osm-priority-coordinates.ts",
    "assist:poi-governance-preview": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/assist-poi-governance-preview.ts",
    "assist:koblenz-goldset-review": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/assist-koblenz-goldset-review.ts",
    "verify:koblenz-goldset": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/verify-koblenz-goldset.ts",
    "compare:koblenz-goldset-sources": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/compare-koblenz-goldset-sources.ts",
    "prioritize:koblenz-goldset-review": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/prioritize-koblenz-goldset-review.ts",
    "quickwin:koblenz-goldset": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/build-koblenz-quickwin-worklist.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@supabase/supabase-js": "^2.93.3",
    "dotenv": "^17.2.3",
    "leaflet": "^1.9.4",
    "next": "16.1.4",
    "next-themes": "^0.4.6",
    "pg": "^8.17.2",
    "prisma": "^7.3.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
